---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Figure from '../components/Figure.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../lib/format';

const albums = (await getCollection('galeri')).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
---

<BaseLayout title="Galeri" description="Dokumentasi foto kegiatan dan fasilitas sekolah.">
  <PageHeader eyebrow="Dokumentasi" title="Galeri Foto" subtitle="Momen kegiatan siswa dan fasilitas sekolah dalam gambar." />

  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    {albums.length === 0 ? (
      <p class="rounded-2xl bg-white p-10 text-center text-slate-500 ring-1 ring-slate-200">Belum ada album galeri.</p>
    ) : (
      <div class="space-y-14">
        {albums.map((album) => (
          <div>
            <div class="flex items-end justify-between gap-4">
              <div>
                <span class="inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-800">{album.data.category}</span>
                <h2 class="mt-2 font-heading text-xl font-bold text-ink sm:text-2xl">{album.data.title}</h2>
              </div>
              {album.data.date && <span class="shrink-0 text-sm text-slate-400">{formatDate(album.data.date)}</span>}
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
              {album.data.images.map((img) => (
                <button
                  class="gallery-item card-lift block overflow-hidden rounded-2xl ring-1 ring-slate-200/70"
                  data-src={img.image}
                  data-caption={img.caption ?? album.data.title}
                >
                  <Figure src={img.image} alt={img.caption ?? album.data.title} ratio="aspect-square" rounded="rounded-none" />
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/85 p-4 backdrop-blur-sm">
    <button id="lb-close" class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20" aria-label="Tutup">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <figure class="max-h-full max-w-4xl text-center">
      <img id="lb-img" src="" alt="" class="mx-auto max-h-[80vh] w-auto rounded-2xl" />
      <figcaption id="lb-cap" class="mt-3 text-sm text-white/80"></figcaption>
    </figure>
  </div>

  <script>
    const lb = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCap = document.getElementById('lb-cap')!;
    const close = document.getElementById('lb-close')!;

    document.querySelectorAll<HTMLElement>('.gallery-item').forEach((el) => {
      el.addEventListener('click', () => {
        lbImg.src = el.dataset.src ?? '';
        lbCap.textContent = el.dataset.caption ?? '';
        lb.classList.remove('hidden');
        lb.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });
    const hide = () => {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    };
    close.addEventListener('click', hide);
    lb.addEventListener('click', (e) => { if (e.target === lb) hide(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hide(); });
  </script>
</BaseLayout>
