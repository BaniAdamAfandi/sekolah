---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Figure from '../components/Figure.astro';
import { getEntry } from 'astro:content';

const site = (await getEntry('pengaturan', 'site'))!.data;
const profil = (await getEntry('profil', 'profil'))!.data;
---

<BaseLayout title="Profil Sekolah" description={`Profil, visi misi, dan sejarah ${site.schoolName}.`}>
  <PageHeader
    eyebrow="Tentang Kami"
    title="Profil Sekolah"
    subtitle={`Mengenal lebih dekat ${site.schoolName}, visi misi, dan sejarahnya.`}
  />

  <!-- Sambutan Kepala Sekolah -->
  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid items-start gap-10 lg:grid-cols-3">
      <div class="lg:col-span-1">
        <div class="overflow-hidden rounded-3xl ring-4 ring-primary-50">
          <Figure src={profil.principalPhoto} alt={profil.principalName} ratio="aspect-[3/4]" rounded="rounded-none" />
        </div>
        <p class="mt-4 text-center font-heading text-lg font-bold text-ink">{profil.principalName}</p>
        <p class="text-center text-sm text-slate-500">Kepala Sekolah</p>
      </div>
      <div class="lg:col-span-2">
        <span class="text-sm font-semibold uppercase tracking-wider text-secondary-600">Sambutan</span>
        <h2 class="mt-2 font-heading text-2xl font-bold text-ink sm:text-3xl">Sambutan Kepala Sekolah</h2>
        <p class="mt-5 whitespace-pre-line leading-relaxed text-slate-600">{profil.principalGreeting}</p>
      </div>
    </div>
  </section>

  <!-- Visi & Misi -->
  <section class="bg-white py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-3xl bg-primary-800 p-8 text-white sm:p-10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/15">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h2 class="mt-5 font-heading text-2xl font-bold">Visi</h2>
          <p class="mt-3 leading-relaxed text-primary-100">{profil.vision}</p>
        </div>
        <div class="rounded-3xl bg-canvas p-8 ring-1 ring-slate-200/70 sm:p-10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-secondary-100 text-secondary-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h2 class="mt-5 font-heading text-2xl font-bold text-ink">Misi</h2>
          <ul class="mt-4 space-y-3">
            {profil.missions.map((m, i) => (
              <li class="flex gap-3">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-800 text-xs font-bold text-white">{i + 1}</span>
                <span class="text-slate-600">{m.point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sejarah -->
  {profil.history && (
    <section class="mx-auto max-w-4xl px-4 py-14 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-wider text-secondary-600">Perjalanan</span>
      <h2 class="mt-2 font-heading text-2xl font-bold text-ink sm:text-3xl">Sejarah Singkat</h2>
      <p class="mt-5 whitespace-pre-line leading-relaxed text-slate-600">{profil.history}</p>
    </section>
  )}
</BaseLayout>
