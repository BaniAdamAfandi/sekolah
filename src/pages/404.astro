---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Halaman Tidak Ditemukan">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <p class="font-heading text-7xl font-bold text-primary-800">404</p>
    <h1 class="mt-4 font-heading text-2xl font-bold text-ink sm:text-3xl">Halaman Tidak Ditemukan</h1>
    <p class="mt-3 text-slate-600">Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.</p>
    <a href="/" class="mt-8 rounded-full bg-primary-800 px-7 py-3.5 font-semibold text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-900">
      Kembali ke Beranda
    </a>
  </section>
</BaseLayout>
