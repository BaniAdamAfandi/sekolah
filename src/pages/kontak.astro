---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getEntry } from 'astro:content';

const site = (await getEntry('pengaturan', 'site'))!.data;
const waLink = site.whatsapp ? `https://wa.me/${site.whatsapp}` : null;

const items = [
  site.address && { label: 'Alamat', value: site.address, href: null, icon: 'map' },
  site.email && { label: 'Email', value: site.email, href: `mailto:${site.email}`, icon: 'mail' },
  site.whatsapp && { label: 'WhatsApp', value: `+${site.whatsapp}`, href: waLink, icon: 'wa' },
  site.phone && { label: 'Telepon', value: site.phone, href: `tel:${site.phone}`, icon: 'phone' },
].filter(Boolean) as { label: string; value: string; href: string | null; icon: string }[];
---

<BaseLayout title="Kontak" description={`Hubungi ${site.schoolName} — alamat, email, dan lokasi.`}>
  <PageHeader eyebrow="Hubungi Kami" title="Kontak & Lokasi" subtitle="Kami senang mendengar dari Anda. Berikut cara menghubungi kami." />

  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Info kontak -->
      <div>
        <div class="space-y-4">
          {items.map((it) => (
            <div class="flex items-start gap-4 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200/70">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary-50 text-primary-800">
                {it.icon === 'map' && <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>}
                {it.icon === 'mail' && <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m18 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m18 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>}
                {it.icon === 'wa' && <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>}
                {it.icon === 'phone' && <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>}
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-slate-400">{it.label}</p>
                {it.href ? (
                  <a href={it.href} class="break-words font-medium text-ink hover:text-primary-700">{it.value}</a>
                ) : (
                  <p class="font-medium text-ink">{it.value}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        {waLink && (
          <a href={waLink} class="mt-6 flex w-full items-center justify-center gap-2 rounded-full bg-green-500 px-6 py-3.5 font-semibold text-white transition-transform hover:-translate-y-0.5 hover:bg-green-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
            Chat via WhatsApp
          </a>
        )}
      </div>

      <!-- Peta -->
      <div class="overflow-hidden rounded-3xl shadow-sm ring-1 ring-slate-200/70">
        {site.mapsEmbed ? (
          <iframe
            src={site.mapsEmbed}
            title={`Lokasi ${site.schoolName}`}
            class="h-full min-h-[360px] w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        ) : (
          <div class="flex h-full min-h-[360px] items-center justify-center bg-slate-100 text-slate-400">Peta belum tersedia</div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
