---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const modules = (await getCollection('modul')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Modul" description="Kumpulan modul dan bahan pembelajaran sekolah.">
  <PageHeader eyebrow="Bahan Pembelajaran" title="Modul" subtitle="Kumpulan modul, presentasi, dan template yang dapat digunakan." />

  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8">
    {modules.length === 0 ? (
      <p class="rounded-2xl bg-white p-10 text-center text-slate-500 ring-1 ring-slate-200">
        Belum ada modul yang tersedia.
      </p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {modules.map((module) => (
          <article class="card-lift flex flex-col rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200/70">
            <span class="w-fit rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-800">
              {module.data.type}
            </span>
            <h2 class="mt-4 font-heading text-xl font-bold text-ink">{module.data.title}</h2>
            {module.data.description && (
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{module.data.description}</p>
            )}
            <a
              href={module.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center justify-center rounded-xl bg-primary-800 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-900"
            >
              Buka {module.data.type}
              <span aria-hidden="true" class="ml-2">↗</span>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
