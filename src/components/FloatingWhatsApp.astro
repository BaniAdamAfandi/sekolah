---
import { getEntry } from 'astro:content';
const site = (await getEntry('pengaturan', 'site'))!.data;
const wa = site.whatsapp?.replace(/\D/g, '');
const link = wa
  ? `https://wa.me/${wa}?text=${encodeURIComponent('Halo, saya ingin bertanya tentang ' + site.schoolName)}`
  : null;
---

{
  link && (
    <a
      href={link}
      target="_blank"
      rel="noopener"
      aria-label="Chat WhatsApp"
      class="group fixed bottom-5 right-5 z-50 flex items-center gap-2 rounded-full bg-green-500 px-4 py-3 text-white shadow-lg shadow-green-600/40 transition-transform hover:-translate-y-0.5 hover:bg-green-600 sm:bottom-6 sm:right-6"
    >
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-40 group-hover:opacity-0"></span>
      <svg class="relative h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884" />
      </svg>
      <span class="relative hidden pr-1 text-sm font-semibold sm:inline">Chat WA</span>
    </a>
  )
}
