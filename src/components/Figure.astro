---
/**
 * Gambar dengan fallback gradient + ikon jika file belum diupload via CMS.
 * Menjaga tata letak (aspect-ratio) agar tidak ada layout shift (CLS).
 */
interface Props {
  src?: string;
  alt: string;
  ratio?: string; // mis. "aspect-video", "aspect-square", "aspect-[4/3]"
  class?: string;
  rounded?: string;
  loading?: 'lazy' | 'eager';
}
const {
  src,
  alt,
  ratio = 'aspect-video',
  class: klass = '',
  rounded = 'rounded-2xl',
  loading = 'lazy',
} = Astro.props;
---

<div class={`relative overflow-hidden ${ratio} ${rounded} ${klass} bg-gradient-to-br from-primary-100 via-primary-50 to-secondary-100`}>
  <div class="absolute inset-0 flex items-center justify-center text-primary-300">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
    </svg>
  </div>
  {
    src && (
      <img
        src={src}
        alt={alt}
        loading={loading}
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
        onerror="this.style.display='none'"
      />
    )
  }
</div>
