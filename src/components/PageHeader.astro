---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
}
const { title, subtitle, eyebrow } = Astro.props;
---

<section class="relative overflow-hidden bg-primary-800 text-white">
  <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full bg-secondary-500/20 blur-2xl"></div>
  <div class="absolute -bottom-24 -left-10 h-72 w-72 rounded-full bg-primary-500/30 blur-2xl"></div>
  <div class="relative mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
    {eyebrow && <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-secondary-300">{eyebrow}</p>}
    <h1 class="font-heading text-3xl font-bold sm:text-4xl">{title}</h1>
    {subtitle && <p class="mt-3 max-w-2xl text-primary-100">{subtitle}</p>}
  </div>
</section>
