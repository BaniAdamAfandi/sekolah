---
import { getEntry } from 'astro:content';
const site = (await getEntry('pengaturan', 'site'))!.data;

const nav = [
  { label: 'Beranda', href: '/' },
  { label: 'Profil', href: '/profil' },
  { label: 'Berita', href: '/berita' },
  { label: 'Guru', href: '/guru' },
  { label: 'Agenda', href: '/agenda' },
  { label: 'Galeri', href: '/galeri' },
  { label: 'Kontak', href: '/kontak' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-slate-200/60 bg-white/85 backdrop-blur-md"
  style="height: var(--header-height)"
>
  <nav class="mx-auto flex h-full max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary-800 text-white font-heading text-lg font-bold shadow-sm">
        T3
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-heading text-base font-bold text-primary-800">{site.schoolName}</span>
        <span class="text-[11px] text-slate-500">Kediri, Jawa Timur</span>
      </span>
    </a>

    <!-- Menu desktop -->
    <ul class="hidden items-center gap-1 lg:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'rounded-full px-3.5 py-2 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'bg-primary-50 text-primary-800'
                  : 'text-slate-600 hover:bg-slate-100 hover:text-primary-800',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <div class="hidden items-center gap-2 lg:flex">
      <a
        href="/ppdb"
        class="rounded-full bg-secondary-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-transform hover:-translate-y-0.5 hover:bg-secondary-600"
      >
        PPDB
      </a>
    </div>

    <!-- Tombol menu mobile -->
    <button
      id="menu-toggle"
      class="inline-flex items-center justify-center rounded-xl p-2 text-primary-800 hover:bg-slate-100 lg:hidden"
      aria-label="Buka menu"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile (drawer) -->
  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white lg:hidden">
    <ul class="space-y-1 px-4 py-4">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block rounded-xl px-4 py-3 text-base font-medium',
                isActive(item.href)
                  ? 'bg-primary-50 text-primary-800'
                  : 'text-slate-700 hover:bg-slate-100',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href="/ppdb" class="block rounded-xl bg-secondary-500 px-4 py-3 text-center text-base font-semibold text-white">
          Info PPDB
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(open === false));
  });
</script>
